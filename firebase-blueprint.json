{
  "entities": {
    "Project": {
      "title": "Project",
      "description": "A portfolio project",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "category": { "type": "string", "enum": ["SaaS", "Web App", "Website", "Tool"] },
        "tags": { "type": "array", "items": { "type": "string" } },
        "imageUrl": { "type": "string" },
        "demoUrl": { "type": "string" },
        "downloadUrl": { "type": "string" },
        "stats": { 
          "type": "array", 
          "items": { 
            "type": "object", 
            "properties": {
              "label": { "type": "string" },
              "value": { "type": "string" }
            }
          }
        },
        "order": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "description", "category", "imageUrl", "createdAt"]
    },
    "Testimonial": {
      "title": "Testimonial",
      "description": "Client feedback",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "role": { "type": "string" },
        "company": { "type": "string" },
        "content": { "type": "string" },
        "avatarUrl": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "role", "company", "content", "avatarUrl", "createdAt"]
    },
    "Skill": {
      "title": "Skill",
      "description": "Technical skill",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "level": { "type": "number" },
        "iconName": { "type": "string" },
        "order": { "type": "number" }
      },
      "required": ["name", "level", "iconName"]
    }
  },
  "firestore": {
    "/projects/{projectId}": {
      "schema": "Project",
      "description": "Collection of portfolio projects"
    },
    "/testimonials/{testimonialId}": {
      "schema": "Testimonial",
      "description": "Collection of client testimonials"
    },
    "/skills/{skillId}": {
      "schema": "Skill",
      "description": "Collection of technical skills"
    },
    "/admins/{adminId}": {
      "schema": {
        "title": "Admin",
        "description": "Admin user record",
        "type": "object",
        "properties": {
          "email": { "type": "string" }
        },
        "required": ["email"]
      },
      "description": "Authorized admin users"
    }
  }
}
